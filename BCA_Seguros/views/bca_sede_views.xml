<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bca_sede_list" model="ir.ui.view">
        <field name="name">bca.sede.list</field>
        <field name="model">bca.sede</field>
        <field name="arch" type="xml">
            <list string="Sedes / Plazas" decoration-muted="not active">
                <field name="name"/>
                <field name="codigo"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_bca_sede_form" model="ir.ui.view">
        <field name="name">bca.sede.form</field>
        <field name="model">bca.sede</field>
        <field name="arch" type="xml">
            <form string="Sede / Plaza">
                <sheet>
                    <widget name="web_ribbon" title="Archivada"
                            bg_color="bg-secondary"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la sede o plaza"/>
                        </h1>
                    </div>
                    <group>
                        <field name="codigo" placeholder="Código interno (opcional)"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bca_sede_search" model="ir.ui.view">
        <field name="name">bca.sede.search</field>
        <field name="model">bca.sede</field>
        <field name="arch" type="xml">
            <search string="Buscar Sedes">
                <field name="name"/>
                <field name="codigo"/>
                <filter name="filter_activas" string="Activas"
                        domain="[('active', '=', True)]"/>
                <filter name="filter_archivadas" string="Archivadas"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_bca_sede" model="ir.actions.act_window">
        <field name="name">Sedes / Plazas</field>
        <field name="res_model">bca.sede</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="BCA_Seguros.view_bca_sede_search"/>
        <field name="context">{'search_default_filter_activas': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Cree la primera sede / plaza de reclutamiento
            </p>
            <p>
                Las sedes ubican geográficamente el reclutamiento de agentes.
                La lista oficial la provee BCA.
            </p>
        </field>
    </record>

</odoo>
