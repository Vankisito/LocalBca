<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         SIC de Reclutamiento (Etapa 12 Fase D, HU-1.9 / 2.1 / 3.1).
         Pivote/gráfica sobre hr.applicant con las dimensiones del embudo:
         reclutadora · sede · puesto · ramo · evento · etapa. La medición de
         velocidad de habilitación se apoya en las fechas nativas de etapa.
         ================================================================ -->

    <record id="view_hr_applicant_pivot_bca" model="ir.ui.view">
        <field name="name">hr.applicant.pivot.bca</field>
        <field name="model">hr.applicant</field>
        <field name="arch" type="xml">
            <pivot string="SIC Reclutamiento">
                <field name="bca_sede_id" type="row"/>
                <field name="stage_id" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_hr_applicant_graph_bca" model="ir.ui.view">
        <field name="name">hr.applicant.graph.bca</field>
        <field name="model">hr.applicant</field>
        <field name="arch" type="xml">
            <graph string="SIC Reclutamiento" type="bar">
                <field name="bca_sede_id"/>
                <field name="stage_id"/>
            </graph>
        </field>
    </record>

    <record id="view_hr_applicant_search_bca" model="ir.ui.view">
        <field name="name">hr.applicant.search.bca</field>
        <field name="model">hr.applicant</field>
        <field name="arch" type="xml">
            <search string="SIC Reclutamiento">
                <field name="partner_name"/>
                <field name="job_id"/>
                <field name="bca_sede_id"/>
                <field name="user_id"/>
                <field name="campaign_id"/>
                <group>
                    <filter name="bca_group_sede" string="Sede"
                            context="{'group_by': 'bca_sede_id'}"/>
                    <filter name="bca_group_reclutadora" string="Reclutadora"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="bca_group_puesto" string="Puesto"
                            context="{'group_by': 'job_id'}"/>
                    <filter name="bca_group_ramo" string="Ramo"
                            context="{'group_by': 'bca_ramo'}"/>
                    <filter name="bca_group_campana" string="Campaña"
                            context="{'group_by': 'campaign_id'}"/>
                    <filter name="bca_group_etapa" string="Etapa"
                            context="{'group_by': 'stage_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sic_reclutamiento" model="ir.actions.act_window">
        <field name="name">SIC Reclutamiento</field>
        <field name="res_model">hr.applicant</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="BCA_Seguros.view_hr_applicant_search_bca"/>
        <field name="context">{'search_default_bca_group_sede': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sin candidatos que reportar todavía
            </p>
            <p>
                Pivote de postulantes por sede, reclutadora, ramo, evento y etapa.
            </p>
        </field>
    </record>

</odoo>
