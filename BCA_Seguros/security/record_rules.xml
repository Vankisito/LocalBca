<odoo>
    <!-- ================================================================
         RECORD RULES — ETAPA 1

         ADVERTENCIA implied_ids (Plan §2.4.3 / corrección A3):
         implied_ids causa membresía ACUMULATIVA. Un usuario Director
         pertenece simultáneamente a: Director, Director Comercial, Líder
         y Operador. Odoo combina las rules del mismo modelo con AND.

         Por eso TODOS los grupos no-agente DEBEN tener una rule
         explícita [(1,'=',1)] en cada modelo con rules propias.
         Sin esta rule, el Director hereda la restricción de Operador
         y queda con acceso CERO si alguna rule del chain es restrictiva.

         Los modelos stub (bca.poliza, bca.recibo, etc.) tendrán sus
         rules en etapas posteriores cuando tengan campos de negocio.
         ================================================================ -->

    <!-- ============================================================
         bca.conducto
         Agentes: sin acceso (no hay entry en ACL para agente)
         Operador, Líder: lectura global
         Director Comercial, Director: lectura/escritura/creación global
         ============================================================ -->
    <record id="rule_bca_conducto_operador" model="ir.rule">
        <field name="name">bca.conducto: acceso global operador</field>
        <field name="model_id" ref="model_bca_conducto"/>
        <field name="groups" eval="[(4, ref('BCA_Seguros.group_bca_operador'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
