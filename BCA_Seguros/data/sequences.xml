<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate="1" OBLIGATORIO en secuencias.
         Sin él, odoo-bin -u resetea number_next a 1 en producción. -->
    <data noupdate="1">

        <record id="seq_recibo" model="ir.sequence">
            <field name="name">Secuencia Recibo BCA</field>
            <field name="code">bca.recibo</field>
            <field name="prefix">REC-%(year)s-</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

        <record id="seq_bca_bitacora_importacion" model="ir.sequence">
            <field name="name">Secuencia Bitácora Importación BCA</field>
            <field name="code">bca.bitacora.importacion</field>
            <field name="prefix">BIT-%(year)s-</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

    </data>
</odoo>
