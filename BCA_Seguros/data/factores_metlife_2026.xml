<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Factores PCA MetLife 2026
         17 registros: 14 Vida (7 productos × 2 monedas) + 3 GMM

         Fuente: Tabla de PCA MetLife vigente desde 2026-01-01.
         base.MXN y base.USD deben estar activas en res.currency antes de instalar.

         Productos Vida con factor asignado en esta tabla:
           Universales, TempoLife, TempoLife GP/RP, TotalLife, EducaLife,
           PerfectLife, Horizonte.
         Productos Vida sin factor todavía (definidos en productos_metlife.xml):
           Perfect Life, Vida Pagos, Metalife Retiro, Metalife tu Futuro.
         Cuando se publique su factor, agregar el registro aquí o crear desde UI
         (editable por Director Comercial y Director General — ver ACL).

         GMM: los 3 factores discriminan por coaseguro/deducible, no por producto
         (sin producto_ids).

         noupdate="1": protege contra sobreescritura en odoo-bin -u. -->
    <data noupdate="1">

        <!-- ============================================================
             VIDA — 14 registros (7 productos × 2 monedas)
             ============================================================ -->

        <record id="factor_metlife_universales_mxn" model="bca.factor.pca">
            <field name="name">MetLife Vida — Universales MXN 2026</field>
            <field name="aseguradora_id" ref="BCA_Seguros.partner_metlife"/>
            <field name="ramo">vida</field>
            <field name="currency_id" ref="base.MXN"/>
            <field name="producto_ids" eval="[(6, 0, [ref('BCA_Seguros.producto_metlife_universales')])]"/>
            <field name="factor">1.0</field>
            <field name="vigencia_desde">2026-01-01</field>
            <field name="activo" eval="True"/>
        </record>

        <record id="factor_metlife_universales_usd" model="bca.factor.pca">
            <field name="name">MetLife Vida — Universales USD 2026</field>
            <field name="aseguradora_id" ref="BCA_Seguros.partner_metlife"/>
            <field name="ramo">vida</field>
            <field name="currency_id" ref="base.USD"/>
            <field name="producto_ids" eval="[(6, 0, [ref('BCA_Seguros.producto_metlife_universales')])]"/>
            <field name="factor">1.0</field>
            <field name="vigencia_desde">2026-01-01</field>
            <field name="activo" eval="True"/>
