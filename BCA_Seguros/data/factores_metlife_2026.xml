        <!-- ============================================================
             GMM — 3 registros
             Sin producto_ids: aplica a cualquier producto GMM MetLife.
             Lógica de selección del calculador (Etapa 7):
               coaseguro >= 10% y deducible >= 29,000 MXN → factor 120%
               coaseguro >= 10% y deducible < 29,000 MXN  → factor 100%
               coaseguro <= 5%  (sin importar deducible)  → factor 0%
             ============================================================ -->

        <record id="factor_metlife_gmm_coas10_ded29k" model="bca.factor.pca">
            <field name="name">MetLife GMM — Coaseguro 10% / Ded ≥29,000 MXN 2026</field>
            <field name="aseguradora_id" ref="BCA_Seguros.partner_metlife"/>
            <field name="ramo">gmm</field>
            <field name="currency_id" ref="base.MXN"/>
            <field name="coaseguro_min">10.0</field>
            <field name="deducible_min">29000.0</field>
            <field name="factor">1.2</field>
            <field name="vigencia_desde">2026-01-01</field>
            <field name="activo" eval="True"/>
        </record>

        <record id="factor_metlife_gmm_coas10_ded0" model="bca.factor.pca">
